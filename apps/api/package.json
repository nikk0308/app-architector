{
  "name": "@mag/api",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "npm run build -w @mag/shared && tsx watch src/index.ts",
    "build": "npm run build -w @mag/shared && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "npm run build -w @mag/shared && vitest run",
    "lint": "npm run build -w @mag/shared && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@mag/shared": "0.1.0",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}